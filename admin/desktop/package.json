{
  "name": "qqbot-desktop-launcher",
  "version": "0.1.0",
  "private": true,
  "main": "main.cjs",
  "scripts": {
    "start": "npm run build:panel && electron .",
    "build:panel": "npm --prefix ../frontend run build",
    "desktop": "npm run build:panel && electron .",
    "dist:win": "npm run build:panel && electron-builder --win portable nsis",
    "check": "node --check main.cjs && node --check preload.cjs",
    "test": "node --test tests/*.test.cjs"
  },
  "build": {
    "appId": "com.qqbot.desktop.launcher",
    "productName": "QQBot Desktop Launcher",
    "directories": {
      "output": "../../release"
    },
    "files": [
      "main.cjs",
      "preload.cjs",
      "package.json",
      "assets/icon.ico"
    ],
    "win": {
      "target": ["portable", "nsis"],
      "icon": "assets/icon.ico"
    },
    "portable": {
      "artifactName": "QQBot-Desktop-Launcher-Portable.exe"
    },
    "nsis": {
      "artifactName": "QQBot-Desktop-Launcher-Setup.exe",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "electron": "43.1.0",
    "electron-builder": "26.15.3"
  }
}
